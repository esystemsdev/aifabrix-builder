{
  "version": 6,
  "semantics": {
    "visibility.show": "When false, the field name is omitted from default portal field lists, embedded credential form field lists, and from public API credentialConfig read models (GET/list with decrypt=false), in addition to any omission driven by encrypted. GET with decrypt=true returns the full decrypted config for authorized callers and does not apply this visibility filter.",
    "visibility.showValue": "UI-only: whether stored values may be shown versus placeholders in form flows that honor this flag. Does not control encryption at rest or public API stripping.",
    "display.enabled": "When false, disables the input in credential forms (create and linked edit).",
    "encrypted": "When true, this config key holds secret material: the server encrypts values at rest, omits the key from public credentialConfig (GET/list with decrypt=false), drives credentialSecretPresence hints, and must stay aligned with CredentialEncryptionService."
  },
