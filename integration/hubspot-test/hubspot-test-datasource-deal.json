{
  "key": "hubspot-test-deal",
  "displayName": "HubSpot Deal",
  "description": "HubSpot deals datasource with field mappings for CRM deal data",
  "systemKey": "hubspot-test",
  "entityType": "recordStorage",
  "resourceType": "deal",
  "enabled": true,
  "version": "1.0.0",
  "primaryKey": [
    "id"
  ],
  "labelKey": [
    "dealName"
  ],
  "metadataSchema": {
    "type": "object",
    "required": [
      "id",
      "externalId",
      "properties"
    ],
    "properties": {
      "id": {
        "type": "string",
        "index": true
      },
      "externalId": {
        "type": "string",
        "index": true
      },
      "dealName": {
        "type": "string",
        "filter": true
      },
      "properties": {
        "type": "object",
        "additionalProperties": true
      },
      "associations": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "dimensions": {
    "stage": {
      "type": "local",
      "field": "stage"
    },
    "pipeline": {
      "type": "local",
      "field": "pipeline"
    }
  },
  "fieldMappings": {
    "attributes": {
      "id": {
        "expression": "{{raw.id}}"
      },
      "externalId": {
        "expression": "{{raw.id}}"
      },
      "dealName": {
        "expression": "{{raw.properties.dealname.value}} | trim"
      },
      "amount": {
        "expression": "{{raw.properties.amount.value}}"
      },
      "currency": {
        "expression": "{{raw.properties.deal_currency_code.value}} | toUpper | trim"
      },
      "stage": {
        "expression": "{{raw.properties.dealstage.value}} | trim"
      },
      "pipeline": {
        "expression": "{{raw.properties.pipeline.value}} | trim"
      },
      "closeDate": {
        "expression": "{{raw.properties.closedate.value}}"
      },
      "dealType": {
        "expression": "{{raw.properties.dealtype.value}} | trim"
      },
      "associatedContacts": {
        "expression": "{{raw.associations.contacts.results}}"
      },
      "createdAt": {
        "expression": "{{raw.properties.createdate.value}}"
      },
      "updatedAt": {
        "expression": "{{raw.properties.hs_lastmodifieddate.value}}"
      }
    }
  },
  "exposed": {
    "description": "Exposed fields for HubSpot deals",
    "schema": {
      "id": "metadata.id",
      "externalId": "metadata.externalId",
      "dealName": "metadata.dealName",
      "amount": "metadata.amount",
      "currency": "metadata.currency",
      "stage": "metadata.stage",
      "pipeline": "metadata.pipeline",
      "closeDate": "metadata.closeDate",
      "dealType": "metadata.dealType",
      "associatedContacts": "metadata.associatedContacts",
      "createdAt": "metadata.createdAt",
      "updatedAt": "metadata.updatedAt"
    }
  },
  "openapi": {
    "enabled": true,
    "documentKey": "hubspot-v3",
    "baseUrl": "https://api.hubapi.com",
    "operations": {
      "list": {
        "operationId": "getDeals",
        "method": "GET",
        "path": "/crm/v3/objects/deals"
      },
      "get": {
        "operationId": "getDeal",
        "method": "GET",
        "path": "/crm/v3/objects/deals/{dealId}"
      },
      "create": {
        "operationId": "createDeal",
        "method": "POST",
        "path": "/crm/v3/objects/deals"
      },
      "update": {
        "operationId": "updateDeal",
        "method": "PATCH",
        "path": "/crm/v3/objects/deals/{dealId}"
      },
      "delete": {
        "operationId": "deleteDeal",
        "method": "DELETE",
        "path": "/crm/v3/objects/deals/{dealId}"
      }
    },
    "autoRbac": true
  }
}
