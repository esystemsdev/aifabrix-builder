{
  "key": "hubspot-test-contact",
  "displayName": "HubSpot Contact",
  "description": "HubSpot contacts datasource with field mappings for CRM contact data",
  "systemKey": "hubspot-test",
  "entityType": "recordStorage",
  "resourceType": "contact",
  "enabled": true,
  "version": "1.0.0",
  "primaryKey": [
    "id"
  ],
  "labelKey": [
    "email"
  ],
  "metadataSchema": {
    "type": "object",
    "required": [
      "id",
      "externalId",
      "properties"
    ],
    "properties": {
      "id": {
        "type": "string",
        "index": true
      },
      "externalId": {
        "type": "string",
        "index": true
      },
      "email": {
        "type": "string",
        "filter": true
      },
      "properties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "dimensions": {
    "email": {
      "type": "local",
      "field": "email"
    },
    "country": {
      "type": "local",
      "field": "country"
    }
  },
  "fieldMappings": {
    "attributes": {
      "id": {
        "expression": "{{raw.id}}"
      },
      "externalId": {
        "expression": "{{raw.id}}"
      },
      "firstName": {
        "expression": "{{raw.properties.firstname.value}} | trim"
      },
      "lastName": {
        "expression": "{{raw.properties.lastname.value}} | trim"
      },
      "email": {
        "expression": "{{raw.properties.email.value}} | trim"
      },
      "phone": {
        "expression": "{{raw.properties.phone.value}} | trim"
      },
      "company": {
        "expression": "{{raw.properties.company.value}} | trim"
      },
      "jobTitle": {
        "expression": "{{raw.properties.jobtitle.value}} | trim"
      },
      "address": {
        "expression": "{{raw.properties.address.value}} | trim"
      },
      "city": {
        "expression": "{{raw.properties.city.value}} | trim"
      },
      "country": {
        "expression": "{{raw.properties.country.value}} | toUpper | trim"
      },
      "createdAt": {
        "expression": "{{raw.properties.createdate.value}}"
      },
      "updatedAt": {
        "expression": "{{raw.properties.hs_lastmodifieddate.value}}"
      }
    }
  },
  "exposed": {
    "description": "Exposed fields for HubSpot contacts",
    "schema": {
      "id": "metadata.id",
      "externalId": "metadata.externalId",
      "firstName": "metadata.firstName",
      "lastName": "metadata.lastName",
      "email": "metadata.email",
      "phone": "metadata.phone",
      "company": "metadata.company",
      "jobTitle": "metadata.jobTitle",
      "address": "metadata.address",
      "city": "metadata.city",
      "country": "metadata.country",
      "createdAt": "metadata.createdAt",
      "updatedAt": "metadata.updatedAt"
    }
  },
  "openapi": {
    "enabled": true,
    "documentKey": "hubspot-v3",
    "baseUrl": "https://api.hubapi.com",
    "operations": {
      "list": {
        "operationId": "getContacts",
        "method": "GET",
        "path": "/crm/v3/objects/contacts"
      },
      "get": {
        "operationId": "getContact",
        "method": "GET",
        "path": "/crm/v3/objects/contacts/{contactId}"
      },
      "create": {
        "operationId": "createContact",
        "method": "POST",
        "path": "/crm/v3/objects/contacts"
      },
      "update": {
        "operationId": "updateContact",
        "method": "PATCH",
        "path": "/crm/v3/objects/contacts/{contactId}"
      },
      "delete": {
        "operationId": "deleteContact",
        "method": "DELETE",
        "path": "/crm/v3/objects/contacts/{contactId}"
      }
    },
    "autoRbac": true
  }
}
