{
  "key": "hubspot-test-company",
  "displayName": "HubSpot Company",
  "description": "HubSpot companies datasource with field mappings for CRM company data",
  "systemKey": "hubspot-test",
  "entityType": "recordStorage",
  "resourceType": "customer",
  "enabled": true,
  "version": "1.0.0",
  "primaryKey": [
    "id"
  ],
  "labelKey": [
    "name"
  ],
  "metadataSchema": {
    "type": "object",
    "required": [
      "id",
      "externalId",
      "properties"
    ],
    "properties": {
      "id": {
        "type": "string",
        "index": true
      },
      "externalId": {
        "type": "string",
        "index": true
      },
      "name": {
        "type": "string",
        "filter": true
      },
      "properties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "dimensions": {
    "country": {
      "type": "local",
      "field": "country"
    },
    "domain": {
      "type": "local",
      "field": "domain"
    }
  },
  "fieldMappings": {
    "attributes": {
      "id": {
        "expression": "{{raw.id}}"
      },
      "externalId": {
        "expression": "{{raw.id}}"
      },
      "name": {
        "expression": "{{raw.properties.name.value}} | trim"
      },
      "domain": {
        "expression": "{{raw.properties.domain.value}} | toLower | trim"
      },
      "country": {
        "expression": "{{raw.properties.country.value}} | toUpper | trim"
      },
      "city": {
        "expression": "{{raw.properties.city.value}} | trim"
      },
      "industry": {
        "expression": "{{raw.properties.industry.value}} | trim"
      },
      "website": {
        "expression": "{{raw.properties.website.value}} | trim"
      },
      "phone": {
        "expression": "{{raw.properties.phone.value}} | trim"
      },
      "createdAt": {
        "expression": "{{raw.properties.createdate.value}}"
      },
      "updatedAt": {
        "expression": "{{raw.properties.hs_lastmodifieddate.value}}"
      }
    }
  },
  "exposed": {
    "description": "Exposed fields for HubSpot companies",
    "schema": {
      "id": "metadata.id",
      "externalId": "metadata.externalId",
      "name": "metadata.name",
      "domain": "metadata.domain",
      "country": "metadata.country",
      "city": "metadata.city",
      "industry": "metadata.industry",
      "website": "metadata.website",
      "phone": "metadata.phone",
      "createdAt": "metadata.createdAt",
      "updatedAt": "metadata.updatedAt"
    }
  },
  "openapi": {
    "enabled": true,
    "documentKey": "hubspot-v3",
    "baseUrl": "https://api.hubapi.com",
    "operations": {
      "list": {
        "operationId": "getCompanies",
        "method": "GET",
        "path": "/crm/v3/objects/companies"
      },
      "get": {
        "operationId": "getCompany",
        "method": "GET",
        "path": "/crm/v3/objects/companies/{companyId}"
      },
      "create": {
        "operationId": "createCompany",
        "method": "POST",
        "path": "/crm/v3/objects/companies"
      },
      "update": {
        "operationId": "updateCompany",
        "method": "PATCH",
        "path": "/crm/v3/objects/companies/{companyId}"
      },
      "delete": {
        "operationId": "deleteCompany",
        "method": "DELETE",
        "path": "/crm/v3/objects/companies/{companyId}"
      }
    },
    "autoRbac": true
  }
}
