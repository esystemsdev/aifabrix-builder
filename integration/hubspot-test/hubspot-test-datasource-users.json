{
  "key": "hubspot-test-users",
  "displayName": "HubSpot Users",
  "resourceType": "person",
  "systemKey": "hubspot-test",
  "enabled": true,
  "entityType": "recordStorage",
  "description": "HubSpot users datasource (minimal v2.4 fixture)",
  "primaryKey": [
    "id"
  ],
  "labelKey": [
    "email"
  ],
  "metadataSchema": {
    "type": "object",
    "required": [
      "id",
      "externalId",
      "properties"
    ],
    "properties": {
      "id": {
        "type": "string",
        "index": true
      },
      "externalId": {
        "type": "string",
        "index": true
      },
      "email": {
        "type": "string",
        "filter": true
      },
      "properties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "dimensions": {
    "department": {
      "type": "local",
      "field": "department"
    }
  },
  "fieldMappings": {
    "attributes": {
      "id": {
        "expression": "{{raw.id}}"
      },
      "externalId": {
        "expression": "{{raw.id}}"
      },
      "email": {
        "expression": "{{raw.properties.email.value}} | trim"
      },
      "department": {
        "expression": "{{raw.properties.department.value}} | trim"
      }
    }
  },
  "exposed": {
    "schema": {
      "id": "metadata.id",
      "externalId": "metadata.externalId",
      "email": "metadata.email",
      "department": "metadata.department"
    }
  },
  "sync": {
    "mode": "pull",
    "schedule": "0 */6 * * *",
    "batchSize": 100
  }
}
